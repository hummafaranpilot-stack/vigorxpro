}
.mt-product-header h3 {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin: 0;
    color: #fff !important;
}
.mt-product-header p {
    font-size: 0.6rem;
