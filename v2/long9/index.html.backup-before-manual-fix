    flex-shrink: 0;
}
.mt-subscription-option.active .mt-radio-dot {
    border-color: #fff;
    background: #fff;
}
.mt-radio-dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
