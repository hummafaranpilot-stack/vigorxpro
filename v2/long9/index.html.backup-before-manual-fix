    flex-direction: column;
    align-items: center;
    padding: 0.5rem;
}
.mt-product-image {
    width: 100%;
    position: relative;
    text-align: center;
    padding: 0.4rem;
    border: 1px solid #bbdefb;
    border-radius: 8px;
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
